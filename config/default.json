{
  "source": "camera",
  "camera_id": 0,
  "video_path": "",
  "frame_width": 640,
  "frame_height": 480,
  "fps_limit": 30,
  "face_detector": {
    "backend": "mediapipe_face_landmarker",
    "model_path": "models/face_landmarker.task",
    "max_num_faces": 1,
    "min_detection_confidence": 0.5,
    "min_tracking_confidence": 0.5,
    "running_mode": "video"
  },
  "smoothing": {
    "ema_alpha": 0.5
  },
  "decision": {
    "stable_frames": 5
  },
  "emotion": {
    "face_backend": "onnx",
    "fallback_to_rule": true,
    "stabilizer": {
      "enabled": true,
      "window_size": 7,
      "min_votes": 4,
      "min_confidence": 0.45,
      "reset_on_no_face": true
    },
    "thresholds": {
      "happy_smile": 0.62,
      "surprise_mouth_open": 0.58,
      "surprise_brow_raise": 0.45,
      "tired_eye_open": 0.32,
      "tired_head_pitch": -8.0,
      "sad_smile": 0.25,
      "sad_head_pitch": -8.0
    },
    "fusion_weights": {
      "face": 0.5,
      "text": 0.3,
      "head_pose": 0.2
    },
    "onnx": {
      "model_path": "models/emotion.onnx",
      "input_type": "face_image",
      "image_size": [224, 224],
      "color_mode": "rgb",
      "labels": [
        "neutral",
        "happiness",
        "surprise",
        "sadness",
        "anger",
        "disgust",
        "fear",
        "contempt"
      ]
    },
    "label_mapping": {
      "happy": "happy",
      "happiness": "happy",
      "sad": "sad",
      "sadness": "sad",
      "surprise": "surprise",
      "tired": "tired",
      "anger": "angry",
      "angry": "angry",
      "fear": "fear",
      "disgust": "disgust",
      "contempt": "contempt",
      "neutral": "neutral"
    }
  },
  "control": {
    "protocol_version": "1.0",
    "default_duration_ms": 1500,
    "default_transition_ms": 400
  },
  "demo": {
    "window_name": "Robot Expression Demo",
    "draw_landmarks": true,
    "draw_fps": true,
    "draw_status": true
  }
}
